{
    "manifest_version": 3,
    "name": "tabs-postMessage",
    "version": "0.0.5",
    "description": "Simple Chrome extension with Bun + TypeScript",
    "permissions": [
      "activeTab", "storage", "tabs"
    ],
    "host_permissions": ["<all_urls>"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["/content_script.js"]
      }
    ],
    "options_page": "options/index.html",
    "action": {
      "default_title": "tabs-postMessage",
      "default_popup": "popup/index.html",
      "default_icon": {
        "16": "icons/16.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
      }
    }
  }